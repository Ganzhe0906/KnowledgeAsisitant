# BibiGPT API - 用于解析音视频内容
# 获取地址: https://b.jimmylv.cn/
BIBIGPT_API_KEY=

# Google Gemini API - 用于 AI 提纯与结构化
# 获取地址: https://aistudio.google.com/
GEMINI_API_KEY=

# Obsidian Bridge 推送地址 (如: https://your-domain.com/api/notifications/send)
OBSIDIAN_BRIDGE_URL=https://ai-diary-flomo.vercel.app/api/notifications/send

# Obsidian API 密钥 (默认值通常为 ai-diary-mcp-key)
OBSIDIAN_API_KEY=ai-diary-mcp-key

# ==========================================
# Telegram Bot 配置
# ==========================================

# 你的 Telegram Bot Token (通过 @BotFather 获取)
TELEGRAM_BOT_TOKEN=

# 你的 Telegram User ID (可通过 @userinfobot 获取)，用于限制只有你才能使用这个 Bot
TELEGRAM_ALLOWED_USER_ID=

# ==========================================
# Upstash QStash 异步队列配置 (必须)
# 解决 Vercel 免费版 60s 和 Telegram Webhook 超时问题
# 免费注册并获取: https://console.upstash.com/qstash
# ==========================================
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
